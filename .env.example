# ============================================================================
# Streaming Agents Quickstart — .env
# ============================================================================
# Copy this file to .env and fill in your values:
#
#     cp .env.example .env
#
# This file is loaded by `uv run deploy` and Terraform. NEVER commit .env.
#
# Two deployment modes:
#
#   A) WORKSHOP / FRESH DEPLOY (recommended)
#      Set TF_VAR_create_atlas_cluster=true. Terraform provisions a new
#      M10 Atlas cluster + DB user + IP allowlist for you. You only need
#      to fill in the REQUIRED section below.
#
#   B) BRING YOUR OWN (advanced)
#      Set TF_VAR_create_atlas_cluster=false. You must provide an
#      EXISTING M10+ cluster with a DB user (readWriteAnyDatabase on
#      admin) and IP allowlist that permits your workshop / laptop IP.
#      M0/M2/M5 tiers will NOT work — Atlas Stream Processing requires
#      M10 or higher.
#
# Run `uv run deploy` interactively. It prompts for anything missing and
# saves the answer back into .env. For unattended CI runs use:
#
#     uv run deploy --non-interactive    # exit 2 on missing creds
#
# Validate connectivity any time without running a deploy:
#
#     uv run preflight                   # all checks
#     uv run preflight --phase asp_setup # before ASP provisioning
# ============================================================================


# ============================================================================
# REQUIRED for every deploy
# ============================================================================

# --- Confluent Cloud ---
# Create at https://confluent.cloud → Settings → API keys → "Cloud resource
# management". The principal MUST hold OrganizationAdmin — terraform/core
# creates a fresh `confluent_environment` and that requires OrgAdmin.
TF_VAR_confluent_cloud_api_key=
TF_VAR_confluent_cloud_api_secret=

# --- AWS Bedrock ---
# IAM user / role with bedrock:InvokeModel on the Anthropic Sonnet 4.6
# inference profile. Verify model access at
#   https://us-east-1.console.aws.amazon.com/bedrock/home → Model access
# (workshop attendees: confirm "global.anthropic.claude-sonnet-4-6" is
# Enabled before deploying — terraform succeeds either way but the LLM
# Flink statement fails at runtime if access is denied).
TF_VAR_aws_bedrock_access_key=
TF_VAR_aws_bedrock_secret_key=
# TF_VAR_aws_session_token=                  # only if using temporary STS creds

# --- Voyage AI (embeddings) ---
# Sign up at https://voyageai.com to get a key. Free tier: 200 RPM.
# The default endpoint uses MongoDB Atlas's hosted Voyage proxy.
TF_VAR_voyage_api_key=

# --- MongoDB Atlas Admin API ---
# Programmatic access key with at least "Project Owner" role on
# ATLAS_PROJECT_ID. Create under: Atlas → Access Manager → Project Access
# → Applications → API Keys → Create.
ATLAS_PUBLIC_KEY=
ATLAS_PRIVATE_KEY=
ATLAS_PROJECT_ID=


# ============================================================================
# MODE A — Workshop / fresh deploy (Terraform-managed cluster)
# ============================================================================
# Terraform provisions a 3-node M10 replica set named ATLAS_CLUSTER_NAME
# in ATLAS_PROJECT_ID, plus a DB user and a 0.0.0.0/0 IP allowlist entry.
# The connection string is written back into .env after provisioning.
#
# Pick a unique cluster name (the default is fine for fresh projects):

TF_VAR_create_atlas_cluster=true
ATLAS_CLUSTER_NAME=streaming-agents-cluster

# Database user created by terraform/atlas (defaults shown).
# `uv run deploy` auto-generates a strong password if you leave it blank.
# TF_VAR_atlas_db_username=streaming_agents_app
# TF_VAR_atlas_db_password=

# Cluster takes 7–15 min to provision. Re-runs of `uv run deploy`
# PRESERVE the cluster (separate Terraform state). To destroy it
# explicitly use:  `uv run destroy --include-cluster`


# ============================================================================
# MODE B — Bring your own cluster (skip Terraform Atlas provisioning)
# ============================================================================
# Uncomment this block and the lines below, then COMMENT OUT the
# TF_VAR_create_atlas_cluster + ATLAS_CLUSTER_NAME lines above.
#
# ATLAS_CLUSTER_NAME must match an EXISTING M10+ cluster in
# ATLAS_PROJECT_ID. `uv run preflight --phase asp_setup` verifies this
# before any deploy work — see TROUBLESHOOTING.md if the check fails
# with "cluster not found".
#
# TF_VAR_create_atlas_cluster=false
# ATLAS_CLUSTER_NAME=<your-existing-cluster-name>
# TF_VAR_mongodb_connection_string=mongodb+srv://<host>.mongodb.net
# TF_VAR_mongodb_username=<existing-user-with-readWriteAnyDatabase>
# TF_VAR_mongodb_password=


# ============================================================================
# Optional overrides
# ============================================================================

# AWS region used by Confluent Kafka cluster, Flink compute pool, and
# Atlas cluster. Bedrock model is region-aware (global. prefix → cross-region).
# TF_VAR_cloud_region=us-east-1

# Override the default Bedrock model with a region-specific or smaller
# inference profile (e.g. us.anthropic.claude-haiku-4-5-20251001-v1:0):
# TF_VAR_bedrock_model_id=global.anthropic.claude-sonnet-4-6

# Voyage AI endpoint — defaults to MongoDB Atlas's hosted proxy.
# Set to https://api.voyageai.com/v1/embeddings for direct upstream.
# TF_VAR_voyage_api_endpoint=https://ai.mongodb.com/v1/embeddings

# MongoDB MCP server — deploy.py auto-provisions to AWS ECS Express if
# these are blank. Override only when running an MCP instance you manage.
# TF_VAR_mcp_server_url=
# TF_VAR_mcp_auth_token=

# Owner email used to tag cloud resources. Defaults to the API key
# owner. Useful when many people share a Confluent Cloud account.
# TF_VAR_owner_email=

# Confluent Cloud organization ID (auto-discovered from the API key —
# only set if you have multi-org access and want to pin one).
# CONFLUENT_CLOUD_ORGANIZATION_ID=


# ============================================================================
# Deployment state (managed automatically by `uv run deploy` — do not edit)
# ============================================================================
# Resume-on-failure breadcrumbs written by deploy.py. Safe to delete to
# force a full re-deploy from the start.
#
# DEPLOY_PHASE                  last completed phase: atlas_terraform |
#                                 mcp_server | terraform | credentials |
#                                 publish_data | asp_setup | flink_dml |
#                                 complete
# DEPLOY_LAST_RUN               ISO timestamp of last invocation
# DEPLOY_LAST_INTERRUPTED_PHASE set on SIGINT/SIGTERM (Ctrl+C)
# DEPLOY_LAST_FAILURE           short error message
# DEPLOY_LAST_FAILED_PHASE      phase that failed
#
# After terraform/core runs the deploy ALSO writes 8 Confluent
# credentials (CONFLUENT_BOOTSTRAP_SERVER, CONFLUENT_KAFKA_API_KEY,
# CONFLUENT_KAFKA_API_SECRET, CONFLUENT_KAFKA_REST_ENDPOINT,
# CONFLUENT_KAFKA_CLUSTER_ID, CONFLUENT_SCHEMA_REGISTRY_URL,
# CONFLUENT_SCHEMA_REGISTRY_API_KEY, CONFLUENT_SCHEMA_REGISTRY_API_SECRET,
# CONFLUENT_FLINK_REST_ENDPOINT). Treat them as deploy artifacts.
